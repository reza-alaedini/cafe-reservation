@model Cafe.Models.Product

@{
    ViewData["Title"] = "حذف محصول";
}

<section class="page-hero">
    <div class="page-eyebrow">حذف محصول</div>
    <h1 class="page-title">حذف @Model.Name</h1>
    <p class="page-subtitle">آیا مطمئن هستید که می‌خواهید این محصول از منوی کافه حذف شود؟</p>
</section>

<div class="panel">
    <div class="row g-4">
        <div class="col-md-4">
            <img src="~/images/@Model.Image" alt="@Model.Name" class="detail-image" />
        </div>
        <div class="col-md-8">
            <dl class="detail-list">
                <div class="detail-row">
                    <dt>نام محصول</dt>
                    <dd>@Html.DisplayFor(model => model.Name)</dd>
                </div>
                <div class="detail-row">
                    <dt>قیمت</dt>
                    <dd>@Html.DisplayFor(model => model.Price)</dd>
                </div>
                <div class="detail-row">
                    <dt>وضعیت</dt>
                    <dd>@(Model.IsAvalible ? "موجود" : "ناموجود")</dd>
                </div>
            </dl>
            <form asp-action="Delete" class="actions mt-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">حذف محصول</button>
                <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
            </form>
        </div>
    </div>
</div>
