@model IEnumerable<Cafe.Models.Product>

@{
    ViewData["Title"] = "منوی کافه";
}

<section class="page-hero">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="page-eyebrow">منوی امروز</div>
            <h1 class="page-title">طعم‌های تازه برای یک قرار خوب</h1>
            <p class="page-subtitle">نوشیدنی‌ها و دسرهای کافه را ببینید، محصول دلخواهتان را پیدا کنید و برای جزئیات بیشتر وارد صفحه محصول شوید.</p>
        </div>
        <div class="col-lg-5">
            <form method="get" action="@Url.Action("Index", "Home")" class="d-flex gap-2">
                <input type="text" name="searchQuery" class="form-control" placeholder="جستجو در منو" />
                <button type="submit" class="btn btn-primary">جستجو</button>
            </form>
        </div>
    </div>
</section>

@if (!Model.Any())
{
    <div class="panel empty-state">محصولی با این جستجو پیدا نشد.</div>
}
else
{
    <section class="menu-grid">
        @foreach (var item in Model)
        {
            <article class="menu-card">
                <img src="~/images/@item.Image" alt="@item.Name" />
                <div class="menu-card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <h2 class="menu-card-title">@Html.DisplayFor(modelItem => item.Name)</h2>
                        <span class="status-badge @(item.IsAvalible ? "available" : "unavailable")">
                            @(item.IsAvalible ? "موجود" : "ناموجود")
                        </span>
                    </div>
                    <p class="menu-card-text mb-0">@Html.DisplayFor(modelItem => item.Description)</p>
                    <div class="mt-auto d-flex justify-content-between align-items-center gap-3">
                        <span class="price-chip">@Html.DisplayFor(modelItem => item.Price)تومان</span>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">مشاهده</a>
                    </div>
                </div>
            </article>
        }
    </section>
}
