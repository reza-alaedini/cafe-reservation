@model IEnumerable<Cafe.Models.Product>

@{
    ViewData["Title"] = "مدیریت محصولات";
}

<section class="page-hero">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <div class="page-eyebrow">پنل مدیریت</div>
            <h1 class="page-title">محصولات کافه</h1>
            <p class="page-subtitle">محصولات منو را از این بخش مدیریت کنید، تصویرها را بررسی کنید و وضعیت موجود بودن را سریع تغییر دهید.</p>
        </div>
        <div class="align-self-lg-center">
            <a asp-action="Create" class="btn btn-primary">افزودن محصول</a>
        </div>
    </div>
</section>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>تصویر</th>
                    <th>نام محصول</th>
                    <th>قیمت</th>
                    <th>توضیحات</th>
                    <th>وضعیت</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="~/images/@item.Image" alt="@item.Name" class="product-thumb" />
                        </td>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>@Html.DisplayFor(modelItem => item.Price)</td>
                        <td class="text-muted">@Html.DisplayFor(modelItem => item.Description)</td>
                        <td>
                            <span class="status-badge @(item.IsAvalible ? "available" : "unavailable")">
                                @(item.IsAvalible ? "موجود" : "ناموجود")
                            </span>
                        </td>
                        <td>
                            <div class="actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">ویرایش</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">جزئیات</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">حذف</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">هنوز محصولی ثبت نشده است.</div>
    }
</div>
