@model Cafe.Models.Product

@{
    var user = ViewBag.UserModel as User;
    ViewData["Title"] = "جزئیات محصول";
}

<section class="page-hero">
    <div class="page-eyebrow">جزئیات محصول</div>
    <h1 class="page-title">@Model.Name</h1>
    <p class="page-subtitle">@Model.Description</p>
</section>

<div class="panel">
    <div class="row g-4 align-items-start">
        <div class="col-lg-6">
            <img class="detail-image" src="~/images/@Model.Image" alt="@Model.Name" />
        </div>
        <div class="col-lg-6">
            <dl class="detail-list">
                <div class="detail-row">
                    <dt>نام محصول</dt>
                    <dd>@Html.DisplayFor(model => model.Name)</dd>
                </div>
                <div class="detail-row">
                    <dt>قیمت</dt>
                    <dd><span class="price-chip">@Html.DisplayFor(model => model.Price)</span></dd>
                </div>
                <div class="detail-row">
                    <dt>وضعیت</dt>
                    <dd>
                        <span class="status-badge @(Model.IsAvalible ? "available" : "unavailable")">
                            @(Model.IsAvalible ? "موجود" : "ناموجود")
                        </span>
                    </dd>
                </div>
                <div class="detail-row">
                    <dt>توضیحات</dt>
                    <dd>@Html.DisplayFor(model => model.Description)</dd>
                </div>
            </dl>
            <div class="actions mt-4">
                @if (user != null && user.Role == Cafe.Enums.Role.ADMIN)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">ویرایش</a>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">بازگشت به محصولات</a>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">بازگشت به منو</a>
                }
            </div>
        </div>
    </div>
</div>
