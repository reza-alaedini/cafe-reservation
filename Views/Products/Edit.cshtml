@model Cafe.Models.Product

@{
    ViewData["Title"] = "ویرایش محصول";
}

<section class="page-hero">
    <div class="page-eyebrow">ویرایش منو</div>
    <h1 class="page-title">ویرایش @Model.Name</h1>
    <p class="page-subtitle">اطلاعات محصول، قیمت، تصویر و وضعیت موجود بودن را به روز کنید.</p>
</section>

<div class="panel">
    <form asp-action="Edit" enctype="multipart/form-data" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <div class="col-md-6">
            <label asp-for="Name" class="form-label">نام محصول</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Price" class="form-label">قیمت</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label">توضیحات</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-md-8">
            <label asp-for="Image" class="form-label">تصویر جدید</label>
            <input asp-for="Image" type="file" class="form-control" />
            <span asp-validation-for="Image" class="text-danger"></span>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" asp-for="IsAvalible" />
                <label class="form-check-label" asp-for="IsAvalible">موجود است</label>
            </div>
        </div>
        <div class="col-12 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
            <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
        </div>
    </form>
</div>
