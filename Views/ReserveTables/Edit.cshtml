@model Cafe.Models.ReserveTable

@{
    ViewData["Title"] = "ویرایش میز";
}

<section class="page-hero">
    <div class="page-eyebrow">ویرایش میز</div>
    <h1 class="page-title">ویرایش میز شماره @Model.Id</h1>
    <p class="page-subtitle">قیمت و وضعیت قابل رزرو بودن این میز را تغییر دهید.</p>
</section>

<div class="panel">
    <form asp-action="Edit" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <div class="col-md-8">
            <label asp-for="Price" class="form-label">قیمت</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" asp-for="IsAvalible" />
                <label class="form-check-label" asp-for="IsAvalible">قابل رزرو است</label>
            </div>
        </div>
        <div class="col-12 actions">
            <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
            <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
        </div>
    </form>
</div>
