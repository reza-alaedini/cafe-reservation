@model Cafe.Models.ReserveTable

@{
    ViewData["Title"] = "حذف میز";
}

<section class="page-hero">
    <div class="page-eyebrow">حذف میز</div>
    <h1 class="page-title">حذف میز شماره @Model.Id</h1>
    <p class="page-subtitle">آیا مطمئن هستید که این میز از فهرست رزرو حذف شود؟</p>
</section>

<div class="panel">
    <dl class="detail-list">
        <div class="detail-row">
            <dt>قیمت</dt>
            <dd>@Html.DisplayFor(model => model.Price)</dd>
        </div>
        <div class="detail-row">
            <dt>وضعیت</dt>
            <dd>@(Model.IsAvalible ? "قابل رزرو" : "غیرفعال")</dd>
        </div>
    </dl>
    <form asp-action="Delete" class="actions mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">حذف میز</button>
        <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
    </form>
</div>
