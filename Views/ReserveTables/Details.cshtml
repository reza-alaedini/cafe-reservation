@model Cafe.Models.ReserveTable

@{
    ViewData["Title"] = "جزئیات میز";
}

<section class="page-hero">
    <div class="page-eyebrow">جزئیات میز</div>
    <h1 class="page-title">میز شماره @Model.Id</h1>
    <p class="page-subtitle">اطلاعات قیمت و وضعیت رزرو این میز.</p>
</section>

<div class="panel">
    <dl class="detail-list">
        <div class="detail-row">
            <dt>قیمت</dt>
            <dd>@Html.DisplayFor(model => model.Price)</dd>
        </div>
        <div class="detail-row">
            <dt>وضعیت</dt>
            <dd>
                <span class="status-badge @(Model.IsAvalible ? "available" : "unavailable")">
                    @(Model.IsAvalible ? "قابل رزرو" : "غیرفعال")
                </span>
            </dd>
        </div>
    </dl>
    <div class="actions mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">ویرایش</a>
        <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
    </div>
</div>
