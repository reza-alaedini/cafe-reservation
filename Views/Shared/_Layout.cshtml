@{
    var user = (User?)Context.Items["User"];
    var title = ViewData["Title"] ?? ViewBag.Title ?? "کافه";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string IsActive(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - کافه رزرو</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark app-navbar">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">کافه رزرو</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="باز کردن منو">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class='nav-link @IsActive("Home")' asp-controller="Home" asp-action="Index">منو</a>
                    </li>
                    @if (user != null)
                    {
                        <li class="nav-item">
                            <a class='nav-link @IsActive("ReservationTables")' asp-controller="ReservationTables" asp-action="Index">
                                @(user.Role == Cafe.Enums.Role.ADMIN ? "همه رزروها" : "رزروهای من")
                            </a>
                        </li>
                        @if (user.Role == Cafe.Enums.Role.ADMIN)
                        {
                            <li class="nav-item">
                                <a class='nav-link @IsActive("ReserveTables")' asp-controller="ReserveTables" asp-action="Index">میزها</a>
                            </li>
                            <li class="nav-item">
                                <a class='nav-link @IsActive("Products")' asp-controller="Products" asp-action="Index">محصولات</a>
                            </li>
                            <li class="nav-item">
                                <a class='nav-link @IsActive("Users")' asp-controller="Users" asp-action="Index">کاربران</a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav ms-auto">
                    @if (user != null)
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm" asp-controller="Users" asp-action="Logout">خروج</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class='nav-link @IsActive("Users")' asp-controller="Users" asp-action="Login">ورود</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-light btn-sm" asp-controller="Users" asp-action="Register">ثبت نام</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="app-main">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
