@model IEnumerable<Cafe.Models.ReservationTables>

@{
    ViewData["Title"] = "رزرو میز";
    var user = (User?)Context.Items["User"];
    var availableTables = ViewBag.AvailableTables as IEnumerable<Cafe.Models.ReserveTable> ?? Enumerable.Empty<Cafe.Models.ReserveTable>();
}

<section class="page-hero">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <div class="page-eyebrow">رزرو میز</div>
            <h1 class="page-title">میزهای قابل رزرو</h1>
            <p class="page-subtitle">قبل از رزرو، شماره میز، هزینه رزرو و وضعیت آن را ببینید و سپس میز دلخواهتان را انتخاب کنید.</p>
        </div>
        @if (user?.Role == Cafe.Enums.Role.ADMIN)
        {
            <div class="align-self-lg-center">
                <a asp-controller="ReserveTables" asp-action="Index" class="btn btn-outline-primary">مدیریت میزها</a>
            </div>
        }
    </div>
</section>

@if (!availableTables.Any())
{
    <div class="panel empty-state mb-4">در حال حاضر میز فعالی برای رزرو وجود ندارد.</div>
}
else
{
    <section class="table-option-grid mb-4">
        @foreach (var table in availableTables)
        {
            <article class="table-option-card">
                <div>
                    <div class="table-option-kicker">میز شماره</div>
                    <h2 class="table-option-title">@table.Id</h2>
                </div>
                <dl class="table-option-meta">
                    <div>
                        <dt>هزینه رزرو</dt>
                        <dd>@table.Price</dd>
                    </div>
                    <div>
                        <dt>وضعیت</dt>
                        <dd><span class="status-badge available">قابل رزرو</span></dd>
                    </div>
                </dl>
                <a asp-action="Create" asp-route-tableId="@table.Id" class="btn btn-primary w-100">انتخاب و رزرو</a>
            </article>
        }
    </section>
}

<section class="page-hero">
    <div class="page-eyebrow">پیگیری رزرو</div>
    <h2 class="section-title mb-0">رزروهای ثبت شده</h2>
    <p class="page-subtitle">رزروهای قبلی خود را ببینید یا جزئیات آن‌ها را بررسی کنید.</p>
</section>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>شماره میز</th>
                    <th>کاربر</th>
                    <th>تاریخ رزرو</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Table.Id)</td>
                        <td>@Html.DisplayFor(modelItem => item.User.Email)</td>
                        <td>@JalaliDate.ToFullDateTime(item.ReserveDate)</td>
                        <td>
                            <div class="actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">ویرایش</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">جزئیات</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">حذف</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">هنوز رزروی ثبت نشده است.</div>
    }
</div>
