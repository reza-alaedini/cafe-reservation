@model Cafe.Models.ReservationTables

@{
    ViewData["Title"] = "رزرو جدید";
    var selectedTable = ViewBag.SelectedTable as Cafe.Models.ReserveTable;
    var reservationConflictTitle = ViewBag.ReservationConflictTitle as string;
    var reservationConflictMessage = ViewBag.ReservationConflictMessage as string;
}

<section class="page-hero">
    <div class="page-eyebrow">رزرو میز</div>
    <h1 class="page-title">ثبت رزرو جدید</h1>
    <p class="page-subtitle">میز دلخواه و زمان رزرو را انتخاب کنید.</p>
</section>

<div class="panel">
    <form asp-action="Create" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-md-6">
            @if (selectedTable != null)
            {
                <input type="hidden" asp-for="TableId" />
                <div class="selected-table-summary">
                    <div>
                        <div class="table-option-kicker">میز انتخاب شده</div>
                        <h2 class="table-option-title">@selectedTable.Id</h2>
                    </div>
                    <dl class="table-option-meta">
                        <div>
                            <dt>هزینه رزرو</dt>
                            <dd>@selectedTable.Price تومان</dd>
                        </div>
                        <div>
                            <dt>وضعیت</dt>
                            <dd><span class="status-badge available">قابل رزرو</span></dd>
                        </div>
                    </dl>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">انتخاب میز دیگر</a>
                </div>
            }
            else
            {
                <label asp-for="TableId" class="form-label">میز</label>
                <select asp-for="TableId" class="form-select" asp-items="ViewBag.TableId"></select>
                <span asp-validation-for="TableId" class="text-danger"></span>
            }
        </div>
        <div class="col-md-6">
            <label for="ReserveDateJalaliDisplay" class="form-label">تاریخ و زمان رزرو</label>
            <div class="jalali-picker" data-jalali-picker>
                <input id="ReserveDateJalali" name="ReserveDateJalali" type="hidden" value="@ViewData["ReserveDateJalali"]" />
                <button id="ReserveDateJalaliDisplay" type="button" class="form-control jalali-picker-button" data-jalali-toggle>انتخاب تاریخ</button>
                <input type="time" class="form-control jalali-time-input" data-jalali-time aria-label="زمان رزرو" />
                <div class="jalali-calendar" data-jalali-calendar hidden></div>
            </div>
            @Html.ValidationMessage("ReserveDateJalali", null, new { @class = "text-danger" })
            <div class="form-text">تاریخ را از تقویم و زمان را از فیلد ساعت انتخاب کنید.</div>
        </div>
        <div class="col-12 actions">
            <button type="submit" class="btn btn-primary">ثبت رزرو</button>
            <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
        </div>
    </form>
</div>

@if (!string.IsNullOrWhiteSpace(reservationConflictMessage))
{
    <div class="modal fade" id="reservationConflictModal" tabindex="-1" aria-labelledby="reservationConflictModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="reservationConflictModalLabel">@(reservationConflictTitle ?? "این زمان قابل رزرو نیست")</h2>
                    <button type="button" class="btn-close ms-0" data-bs-dismiss="modal" aria-label="بستن"></button>
                </div>
                <div class="modal-body">
                    @reservationConflictMessage
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">انتخاب زمان دیگر</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (!string.IsNullOrWhiteSpace(reservationConflictMessage))
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var modalElement = document.getElementById('reservationConflictModal');
                if (modalElement && window.bootstrap) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                }
            });
        </script>
    }
}
