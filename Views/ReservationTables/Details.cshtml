@model Cafe.Models.ReservationTables

@{
    ViewData["Title"] = "جزئیات رزرو";
}

<section class="page-hero">
    <div class="page-eyebrow">جزئیات رزرو</div>
    <h1 class="page-title">رزرو میز @Model.Table.Id</h1>
    <p class="page-subtitle">اطلاعات کامل این رزرو در این بخش نمایش داده می‌شود.</p>
</section>

<div class="panel">
    <dl class="detail-list">
        <div class="detail-row">
            <dt>شماره میز</dt>
            <dd>@Html.DisplayFor(model => model.Table.Id)</dd>
        </div>
        <div class="detail-row">
            <dt>کاربر</dt>
            <dd>@Html.DisplayFor(model => model.User.Email)</dd>
        </div>
        <div class="detail-row">
            <dt>تاریخ رزرو</dt>
            <dd>@Html.DisplayFor(model => model.ReserveDate)</dd>
        </div>
    </dl>
    <div class="actions mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">ویرایش</a>
        <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
    </div>
</div>
