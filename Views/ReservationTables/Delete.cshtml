@model Cafe.Models.ReservationTables

@{
    ViewData["Title"] = "حذف رزرو";
}

<section class="page-hero">
    <div class="page-eyebrow">حذف رزرو</div>
    <h1 class="page-title">حذف رزرو میز @Model.Table.Id</h1>
    <p class="page-subtitle">آیا مطمئن هستید که این رزرو حذف شود؟ این عملیات قابل بازگشت نیست.</p>
</section>

<div class="panel">
    <dl class="detail-list">
        <div class="detail-row">
            <dt>شماره میز</dt>
            <dd>@Html.DisplayFor(model => model.Table.Id)</dd>
        </div>
        <div class="detail-row">
            <dt>کاربر</dt>
            <dd>@Html.DisplayFor(model => model.User.Email)</dd>
        </div>
        <div class="detail-row">
            <dt>تاریخ رزرو</dt>
            <dd>@JalaliDate.ToFullDateTime(Model.ReserveDate)</dd>
        </div>
    </dl>
    <form asp-action="Delete" class="actions mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">حذف رزرو</button>
        <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
    </form>
</div>
