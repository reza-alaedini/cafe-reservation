@model Cafe.Models.User

@{
    ViewData["Title"] = "ثبت نام";
}

<section class="page-hero auth-wrap">
    <div class="page-eyebrow">شروع کنید</div>
    <h1 class="page-title">ساخت حساب کاربری</h1>
    <p class="page-subtitle">با ثبت نام، می‌توانید رزروهای خود را مدیریت کنید.</p>
</section>

<div class="panel auth-wrap">
    <form asp-action="Register" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-12">
            <label asp-for="Email" class="form-label">ایمیل</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="UserName" class="form-label">نام کاربری</label>
            <input asp-for="UserName" class="form-control" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Password" class="form-label">رمز عبور</label>
            <input asp-for="Password" type="password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="col-12 d-grid">
            <button type="submit" class="btn btn-primary">ثبت نام</button>
        </div>
        <div class="col-12 text-center">
            <a asp-action="Login">قبلا ثبت نام کرده‌اید؟ وارد شوید</a>
        </div>
    </form>
</div>
