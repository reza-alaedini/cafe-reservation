@model Cafe.Models.User

@{
    ViewData["Title"] = "جزئیات کاربر";
}

<section class="page-hero">
    <div class="page-eyebrow">پرونده کاربر</div>
    <h1 class="page-title">@(Model.Name ?? Model.UserName)</h1>
    <p class="page-subtitle">اطلاعات حساب کاربری و مشخصات تماس.</p>
</section>

<div class="panel">
    <dl class="detail-list">
        <div class="detail-row">
            <dt>نام</dt>
            <dd>@(Model.Name ?? "-")</dd>
        </div>
        <div class="detail-row">
            <dt>نام کاربری</dt>
            <dd>@Html.DisplayFor(model => model.UserName)</dd>
        </div>
        <div class="detail-row">
            <dt>ایمیل</dt>
            <dd>@Html.DisplayFor(model => model.Email)</dd>
        </div>
        <div class="detail-row">
            <dt>تلفن</dt>
            <dd>@(Model.Phone ?? "-")</dd>
        </div>
        <div class="detail-row">
            <dt>تاریخ تولد</dt>
            <dd>@Html.DisplayFor(model => model.Birthdate)</dd>
        </div>
        <div class="detail-row">
            <dt>تاریخ عضویت</dt>
            <dd>@Html.DisplayFor(model => model.CreatedAt)</dd>
        </div>
    </dl>
    <div class="actions mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">ویرایش</a>
        <a asp-action="Index" class="btn btn-outline-secondary">بازگشت</a>
    </div>
</div>
