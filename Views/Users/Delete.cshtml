@model Cafe.Models.User

@{
    ViewData["Title"] = "حذف کاربر";
}

<section class="page-hero">
    <div class="page-eyebrow">حذف کاربر</div>
    <h1 class="page-title">حذف @(Model.Name ?? Model.UserName)</h1>
    <p class="page-subtitle">آیا مطمئن هستید که این کاربر حذف شود؟</p>
</section>

<div class="panel">
    <dl class="detail-list">
        <div class="detail-row">
            <dt>نام</dt>
            <dd>@(Model.Name ?? "-")</dd>
        </div>
        <div class="detail-row">
            <dt>ایمیل</dt>
            <dd>@Html.DisplayFor(model => model.Email)</dd>
        </div>
        <div class="detail-row">
            <dt>تلفن</dt>
            <dd>@(Model.Phone ?? "-")</dd>
        </div>
        <div class="detail-row">
            <dt>تاریخ عضویت</dt>
            <dd>@Html.DisplayFor(model => model.CreatedAt)</dd>
        </div>
    </dl>
    <form asp-action="Delete" class="actions mt-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">حذف کاربر</button>
        <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
    </form>
</div>
