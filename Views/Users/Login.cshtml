@model Cafe.Models.LoginModel

@{
    ViewData["Title"] = "ورود";
}

<section class="page-hero auth-wrap">
    <div class="page-eyebrow">خوش آمدید</div>
    <h1 class="page-title">ورود به کافه رزرو</h1>
    <p class="page-subtitle">برای مدیریت رزروها یا ثبت سفارش، وارد حساب خود شوید.</p>
</section>

<div class="panel auth-wrap">
    <form asp-action="Login" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-12">
            <label asp-for="Email" class="form-label">ایمیل</label>
            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Password" class="form-label">رمز عبور</label>
            <input asp-for="Password" type="password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="col-12 d-grid">
            <button type="submit" class="btn btn-primary">ورود</button>
        </div>
        <div class="col-12 text-center">
            <a asp-action="Register">حساب ندارید؟ ثبت نام کنید</a>
        </div>
    </form>
</div>
