@model IEnumerable<Cafe.Models.User>

@{
    ViewData["Title"] = "کاربران";
}

<section class="page-hero">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <div class="page-eyebrow">مدیریت کاربران</div>
            <h1 class="page-title">کاربران سیستم</h1>
            <p class="page-subtitle">اطلاعات کاربران ثبت نام شده را بررسی و مدیریت کنید.</p>
        </div>
        <div class="align-self-lg-center">
            <a class="btn btn-primary" asp-action="Create">افزودن کاربر</a>
        </div>
    </div>
</section>

<div class="table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>نام</th>
                    <th>نام کاربری</th>
                    <th>ایمیل</th>
                    <th>تلفن</th>
                    <th>نقش</th>
                    <th>تاریخ عضویت</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@(item.Name ?? "-")</td>
                        <td>@Html.DisplayFor(modelItem => item.UserName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>@(item.Phone ?? "-")</td>
                        <td><span class="status-badge available">@(item.Role?.ToString() ?? "USER")</span></td>
                        <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                        <td>
                            <div class="actions">
                                <a class="btn btn-outline-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">ویرایش</a>
                                <a class="btn btn-outline-secondary btn-sm" asp-action="Details" asp-route-id="@item.Id">جزئیات</a>
                                <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">حذف</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">هنوز کاربری ثبت نشده است.</div>
    }
</div>
